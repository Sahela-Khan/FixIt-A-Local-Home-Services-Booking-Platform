# Copy this file to .env and fill in your own values. NEVER commit .env to git.
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/fixit?retryWrites=true&w=majority
JWT_SECRET=replace_this_with_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Used only by: npm run seed:admin
ADMIN_NAME=FixIt Admin
ADMIN_EMAIL=admin@fixit.com
ADMIN_PASSWORD=ChangeMe123!
